# ======================
# AI DJ Assist - Environment Variables
# Copy to .env and fill in your values
# ======================

# Database (PostgreSQL for backend)
AIDJ_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/aidj

# JWT Authentication (RS256)
# Generate keys: openssl genrsa -out keys/private.pem 2048
#                openssl rsa -in keys/private.pem -pubout -out keys/public.pem
AIDJ_JWT_PRIVATE_KEY_PATH=./keys/private.pem
AIDJ_JWT_PUBLIC_KEY_PATH=./keys/public.pem

# OAuth - Google
AIDJ_GOOGLE_CLIENT_ID=your-google-client-id
AIDJ_GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Apple
AIDJ_APPLE_CLIENT_ID=your-apple-client-id

# Stripe Billing
AIDJ_STRIPE_SECRET_KEY=sk_test_xxx
AIDJ_STRIPE_WEBHOOK_SECRET=whsec_xxx
AIDJ_STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
AIDJ_STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx

# CORS (comma-separated origins)
AIDJ_CORS_ORIGINS=tauri://localhost

# B2B API (optional)
AIDJ_B2B_RATE_LIMIT=1000
